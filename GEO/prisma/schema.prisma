generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model POI {
  id          String   @id @default(cuid())
  name        String
  category    String   // restaurant, hotel, site, leisure
  latitude    Float
  longitude   Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([latitude, longitude])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  @@index([email])
}